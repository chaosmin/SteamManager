# SteamManager — environment variables
# Copy this file to .env and fill in values before first run

# Required: AES-256 key for encrypting Steam session token (min 32 chars)
SESSION_ENCRYPTION_KEY=change-me-to-a-random-32-char-secret

# Required: password to access the Web UI
UI_ACCESS_PASSWORD=change-me

# MySQL connection (external instance)
DB_HOST=192.168.1.100
DB_PORT=3306
DB_NAME=steam_manager
DB_USER=steam_mgr
DB_PASSWORD=change-me
