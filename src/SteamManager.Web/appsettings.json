  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "File", "Args": { "path": "logs/steam-manager-.log", "rollingInterval": "Day" } }
    ]
  },
  "AllowedHosts": "*"
}
