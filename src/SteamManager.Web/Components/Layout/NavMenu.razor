<MudNavMenu>
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
        Dashboard
    </MudNavLink>
    <MudNavLink Href="games" Icon="@Icons.Material.Filled.SportsEsports">
        Games
    </MudNavLink>
    <MudNavLink Href="settings" Icon="@Icons.Material.Filled.Settings">
        Settings
    </MudNavLink>
</MudNavMenu>

<MudSpacer />

<MudText Typo="Typo.caption" Class="pa-4" Style="opacity:0.4">@_version</MudText>

@code {
    private static readonly string _version =
        (System.Reflection.CustomAttributeExtensions
            .GetCustomAttribute<System.Reflection.AssemblyInformationalVersionAttribute>(
                typeof(NavMenu).Assembly)
            ?.InformationalVersion ?? "dev")
        .Split('+')[0];
}
