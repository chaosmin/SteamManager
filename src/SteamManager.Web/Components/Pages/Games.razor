@page "/games"
@rendermode InteractiveServer
@inject AppDbContext Db
@inject IGameIdleService IdleService
@inject IGameQueueService QueueService
@inject IGameRefreshService RefreshService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject ISteamSessionService Session
@inject SteamWebApiClient SteamApi
@inject SteamCommunityClient CommunityClient
@using SteamManager.Core.Services
@using SteamManager.Infrastructure.Persistence
@using SteamManager.Infrastructure.Http
@using SteamManager.Core.Models
@using Microsoft.EntityFrameworkCore

<div class="d-flex align-center justify-space-between mb-4">
    <MudText Typo="Typo.h4">Games</MudText>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Sync"
               OnClick="SyncLibrary" Disabled="_syncing">
        @(_syncing ? "Syncing..." : "Sync Library")
    </MudButton>
</div>


@if (_loading)
{
    <!-- Skeleton loading grid -->
    <div class="d-flex align-center flex-wrap gap-4 mb-4">
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="240px" Height="40px" />
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="160px" Height="40px" />
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="130px" Height="32px" />
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="60px" Height="32px" />
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="150px" Height="32px" />
    </div>
    <MudGrid Spacing="3">
        @for (int i = 0; i < 8; i++)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudPaper Elevation="3" Style="overflow:hidden;border-radius:4px">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="120px" />
                    <div style="padding:12px">
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="80%" Class="mb-2" />
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="50%" Class="mb-2" />
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="6px" />
                    </div>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}
else
{
    <!-- Filter bar -->
    <div class="d-flex align-center flex-wrap gap-4 mb-4">
        <MudTextField @bind-Value="_search" Placeholder="Search games..." Variant="Variant.Outlined"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Clearable="true" FullWidth="false" Style="min-width:240px" Dense="true"
                      Immediate="true" />
        <MudSelect @bind-Value="_sortOption" Dense="true" Variant="Variant.Outlined"
                   Style="min-width:160px" Label="Sort by">
            <MudSelectItem Value="SortOption.NameAsc">Name A→Z</MudSelectItem>
            <MudSelectItem Value="SortOption.NameDesc">Name Z→A</MudSelectItem>
            <MudSelectItem Value="SortOption.PlaytimeAsc">Playtime ↑</MudSelectItem>
            <MudSelectItem Value="SortOption.PlaytimeDesc">Playtime ↓</MudSelectItem>
            <MudSelectItem Value="SortOption.AchAsc">Achievements ↑</MudSelectItem>
            <MudSelectItem Value="SortOption.AchDesc">Achievements ↓</MudSelectItem>
        </MudSelect>
        <MudSwitch @bind-Value="_onlyWithAchievements" Color="Color.Primary" Label="Has achievements" />
        <MudSwitch @bind-Value="_onlyCompleted" Color="Color.Success" Label="100%" />
        <MudSwitch @bind-Value="_onlyWithCardDrops" Color="Color.Warning" Label="Card drops remaining" />
    </div>

    @if (_games.Count == 0)
    {
        <MudPaper Elevation="2" Style="padding:48px 24px;border-radius:12px;text-align:center;border:1px dashed rgba(102,192,244,0.3)">
            <MudIcon Icon="@Icons.Material.Filled.VideogameAsset" Style="font-size:56px;color:rgba(102,192,244,0.4);margin-bottom:16px" />
            <MudText Typo="Typo.h6" Style="color:rgba(255,255,255,0.75);margin-bottom:8px">Library is empty</MudText>
            <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.5);margin-bottom:24px">
                Import your Steam library to get started. Requires a Web API key in Settings.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Sync"
                       OnClick="SyncLibrary" Disabled="_syncing">
                @(_syncing ? "Syncing..." : "Sync Library")
            </MudButton>
        </MudPaper>
    }
    else
    {
        var filtered = _games
            .Where(g => string.IsNullOrWhiteSpace(_search) ||
                        g.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))
            .Where(g => !_onlyWithAchievements || (_achStats.GetValueOrDefault(g.Id)?.Total ?? 0) > 0)
            .Where(g =>
            {
                var s = _achStats.GetValueOrDefault(g.Id);
                var allDone = s != null && s.Total > 0 && s.Unlocked == s.Total;
                return _onlyCompleted ? allDone : !allDone;
            })
            .Where(g => !_onlyWithCardDrops || g.DropsRemaining > 0)
            .ToList();

        filtered = _sortOption switch
        {
            SortOption.NameAsc      => filtered.OrderBy(g => g.NameI18n ?? g.Name).ToList(),
            SortOption.NameDesc     => filtered.OrderByDescending(g => g.NameI18n ?? g.Name).ToList(),
            SortOption.PlaytimeAsc  => filtered.OrderBy(RemainingMinutes).ToList(),
            SortOption.PlaytimeDesc => filtered.OrderByDescending(RemainingMinutes).ToList(),
            SortOption.AchAsc       => filtered.OrderBy(g => (_achStats.GetValueOrDefault(g.Id)?.Total ?? 0) - (_achStats.GetValueOrDefault(g.Id)?.Unlocked ?? 0)).ToList(),
            SortOption.AchDesc      => filtered.OrderByDescending(g => (_achStats.GetValueOrDefault(g.Id)?.Total ?? 0) - (_achStats.GetValueOrDefault(g.Id)?.Unlocked ?? 0)).ToList(),
            _                       => filtered,
        };

        @if (filtered.Count == 0)
        {
            <MudPaper Elevation="1" Style="padding:32px 24px;border-radius:12px;text-align:center;border:1px dashed rgba(255,255,255,0.1)">
                <MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Style="font-size:40px;color:rgba(255,255,255,0.2);margin-bottom:12px" />
                <MudText Typo="Typo.body1" Style="color:rgba(255,255,255,0.5)">No games match the current filters</MudText>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="3">
                @foreach (var game in filtered)
                {
                    var played = game.SteamPlaytimeAtRefresh;
                    var stats = _achStats.GetValueOrDefault(game.Id);
                    var achTotal = stats?.Total ?? 0;
                    var achDone = stats?.Unlocked ?? 0;
                    var queuePos = GetQueuePosition(game.Id);
                    var hasRefPlayer = game.ReferencePlayer != null;

                    var refMinutes = game.TargetMinutes is > 0 ? game.TargetMinutes.Value : 600;

                    double playGreenPct, playSecondPct;
                    string secondColor;
                    if (refMinutes > 0 && played <= refMinutes)
                    {
                        playGreenPct = played * 100.0 / refMinutes;
                        playSecondPct = 100.0 - playGreenPct;
                        secondColor = "#f44336";
                    }
                    else if (refMinutes > 0 && played > refMinutes)
                    {
                        playGreenPct = refMinutes * 100.0 / played;
                        playSecondPct = 100.0 - playGreenPct;
                        secondColor = "#ff9800";
                    }
                    else
                    {
                        playGreenPct = 0; playSecondPct = 100; secondColor = "rgba(255,255,255,0.12)";
                    }

                    double achGreenPct = achTotal > 0 ? achDone * 100.0 / achTotal : 0;
                    double achRedPct = 100.0 - achGreenPct;

                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudCard Elevation="3" Class="game-card" Style="overflow:hidden;height:100%;display:flex;flex-direction:column">
                            <div style="position:relative;cursor:pointer" @onclick="@(() => Nav.NavigateTo($"/games/{game.Id}"))">
                                @if (queuePos.HasValue && game.Status == GameStatus.Idle)
                                {
                                    <MudBadge Content="@((queuePos.Value + 1).ToString())"
                                              Overlap="true" Bordered="true"
                                              Color="Color.Info">
                                        <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/@(game.AppId)/header.jpg"
                                             style="width:100%;display:block;aspect-ratio:460/215;object-fit:cover"
                                             onerror="this.src=''" />
                                    </MudBadge>
                                }
                                else
                                {
                                    <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/@(game.AppId)/header.jpg"
                                         style="width:100%;display:block;aspect-ratio:460/215;object-fit:cover"
                                         onerror="this.src=''" />
                                }
                                <div style="position:absolute;top:6px;right:6px">
                                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(game.Status)"
                                             Style="font-size:0.7rem;height:22px">@game.Status</MudChip>
                                </div>
                            </div>

                            <MudCardContent Style="flex:1;padding-bottom:4px">
                                <MudText Typo="Typo.subtitle1" Class="mb-2"
                                         Style="@($"font-weight:600;line-height:1.2;{(achTotal > 0 && achDone == achTotal ? "color:#4caf50" : "")}")">
                                    @(game.NameI18n ?? game.Name)
                                </MudText>

                                <MudText Typo="Typo.caption" Class="mb-1" Style="color:rgba(255,255,255,0.6)">
                                    @($"{played / 60.0:F1}h") / @($"{refMinutes / 60.0:F1}h")
                                    @if (achTotal > 0) { <span style="font-size:0.7rem"> avg</span> }
                                </MudText>
                                <div style="display:flex;height:6px;border-radius:3px;overflow:hidden;background:rgba(255,255,255,0.12);margin-bottom:8px">
                                    @if (playGreenPct > 0)
                                    {
                                        <div style="width:@(playGreenPct.ToString("F1"))%;background:#4caf50"></div>
                                    }
                                    @if (playSecondPct > 0)
                                    {
                                        <div style="width:@(playSecondPct.ToString("F1"))%;background:@secondColor"></div>
                                    }
                                </div>

                                @if (achTotal > 0)
                                {
                                    <MudText Typo="Typo.caption" Class="mb-1" Style="color:rgba(255,255,255,0.6)">
                                        Achievements: @achDone / @achTotal
                                    </MudText>
                                    <div style="display:flex;height:6px;border-radius:3px;overflow:hidden;background:rgba(255,255,255,0.12)">
                                        @if (achGreenPct > 0)
                                        {
                                            <div style="width:@(achGreenPct.ToString("F1"))%;background:#4caf50"></div>
                                        }
                                        @if (achRedPct > 0)
                                        {
                                            <div style="width:@(achRedPct.ToString("F1"))%;background:#f44336"></div>
                                        }
                                    </div>
                                }
                            </MudCardContent>

                            <MudCardActions Style="padding-top:0">
                                @if (achTotal > 0)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Info" Size="Size.Small"
                                                   OnClick="@(() => Nav.NavigateTo($"/games/{game.Id}"))" />
                                }
                                @if (game.Status == GameStatus.Playing)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                               OnClick="@(() => StopGame(game.AppId))">Stop</MudButton>
                                }
                                else if (game.Status == GameStatus.Scheduled)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">Scheduled</MudChip>
                                }
                                else if (game.Status == GameStatus.Completed)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                                               OnClick="@(() => ForceRefreshGame(game.Id, game.AppId))">Force Refresh</MudButton>
                                }
                                else if (queuePos.HasValue)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                                               OnClick="@(() => RefreshGame(game.Id, game.AppId))">Re-Refresh</MudButton>
                                }
                                else if (!hasRefPlayer)
                                {
                                    <MudTooltip Text="Configure a reference player in game detail first">
                                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="true">Refresh</MudButton>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                               OnClick="@(() => RefreshGame(game.Id, game.AppId))">Refresh</MudButton>
                                }
                                <MudSpacer />
                                @if (_serverValidatedAppIds.Contains(game.AppId))
                                {
                                    <MudTooltip Text="Server-validated achievements — cannot be auto-unlocked">
                                        <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small"
                                                 Style="color:rgba(255,165,0,0.75);margin-right:6px;margin-bottom:2px" />
                                    </MudTooltip>
                                }
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    }
}

@code {
    record AchievementStats(int Total, int Unlocked);
    enum SortOption { NameAsc, NameDesc, PlaytimeAsc, PlaytimeDesc, AchAsc, AchDesc }

    List<Game> _games = [];
    List<QueueEntry> _queue = [];
    Dictionary<int, AchievementStats> _achStats = [];
    HashSet<int> _serverValidatedAppIds = [];
    bool _loading = true;
    bool _syncing;
    string _search = "";
    bool _onlyWithAchievements;
    bool _onlyCompleted;
    bool _onlyWithCardDrops;
    SortOption _sortOption = SortOption.NameAsc;

    int RemainingMinutes(Game g)
    {
        var refMin = g.TargetMinutes is > 0 ? g.TargetMinutes.Value : 600;
        return Math.Max(0, refMin - g.SteamPlaytimeAtRefresh);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await RefreshAsync();
        StateHasChanged();
    }

    async Task RefreshAsync()
    {
        _games = await Db.Games
            .Include(g => g.ReferencePlayer)
            .AsNoTracking()
            .ToListAsync();
        _queue = await QueueService.GetQueueAsync();
        var raw = await Db.Achievements
            .AsNoTracking()
            .GroupBy(a => a.GameId)
            .Select(g => new
            {
                GameId = g.Key,
                Total = g.Count(),
                Unlocked = g.Count(a => a.IsUnlocked),
            })
            .ToListAsync();
        _achStats = raw.ToDictionary(s => s.GameId, s => new AchievementStats(s.Total, s.Unlocked));
        var failedAppIds = await Db.SteamAuditLogs
            .Where(l => l.Operation == "StoreUserStats" && !l.Success && l.AppId != null)
            .Select(l => l.AppId!.Value)
            .Distinct()
            .ToListAsync();
        _serverValidatedAppIds = failedAppIds.ToHashSet();
        _loading = false;
    }

    int? GetQueuePosition(int gameId)
        => _queue.FirstOrDefault(q => q.GameId == gameId)?.Position;

    async Task RefreshGame(int gameId, int appId)
    {
        try
        {
            await RefreshService.RefreshAsync(gameId, appId);
            _queue = await QueueService.GetQueueAsync();
            await RefreshAsync();
            Snackbar.Add("Refresh complete — game added to queue.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    async Task ForceRefreshGame(int gameId, int appId)
    {
        try
        {
            await RefreshService.ForceRefreshAsync(gameId, appId);
            _queue = await QueueService.GetQueueAsync();
            await RefreshAsync();
            Snackbar.Add("Force refresh complete.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    async Task StartGame(int appId)
    {
        try
        {
            var currentlyRunning = _games.FirstOrDefault(g => g.Status == GameStatus.Playing && g.AppId != appId);
            if (currentlyRunning != null)
            {
                await IdleService.StopAsync(currentlyRunning.AppId);
                Snackbar.Add($"Stopped {currentlyRunning.NameI18n ?? currentlyRunning.Name}", Severity.Info);
            }

            await IdleService.StartAsync(appId);
            await RefreshAsync();
            Snackbar.Add("Game started", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Failed to start: {ex.Message}", Severity.Error); }
    }

    async Task StopGame(int appId)
    {
        await IdleService.StopAsync(appId);
        _queue = await QueueService.GetQueueAsync();
        await RefreshAsync();
        Snackbar.Add("Game stopped", Severity.Info);
    }

    async Task SyncLibrary()
    {
        if (Session.SteamId64 == null) { Snackbar.Add("Not logged in to Steam", Severity.Warning); return; }
        var cfg = await Db.SteamConfigs.FirstOrDefaultAsync();
        if (cfg?.WebApiKey == null) { Snackbar.Add("Steam Web API key not set — configure it in Settings", Severity.Warning); return; }

        _syncing = true;
        try
        {
            var language = cfg.Language ?? "english";
            var owned = await SteamApi.GetOwnedGamesAsync(Session.SteamId64.Value, cfg.WebApiKey, language);
            var existingGames = await Db.Games.ToListAsync();
            var existingMap = existingGames.ToDictionary(g => g.AppId);
            int added = 0;
            foreach (var (appId, name, playtimeMinutes) in owned)
            {
                if (existingMap.TryGetValue(appId, out var existing))
                {
                    if (language == "english") { existing.Name = name; existing.NameI18n = null; }
                    else existing.NameI18n = name;
                    existing.SteamPlaytimeAtRefresh = playtimeMinutes;
                }
                else
                {
                    Db.Games.Add(new Game
                    {
                        AppId = appId,
                        Name = name,
                        NameI18n = language != "english" ? name : null,
                        SteamPlaytimeAtRefresh = playtimeMinutes,
                    });
                    added++;
                }
            }
            await Db.SaveChangesAsync();

            try
            {
                var drops = await CommunityClient.GetCardDropsRemainingAsync(Session.SteamId64.Value);
                var allGames = await Db.Games.ToListAsync();
                foreach (var game in allGames)
                    game.DropsRemaining = drops.TryGetValue(game.AppId, out var d) ? d : 0;
                await Db.SaveChangesAsync();
                Snackbar.Add($"Synced {owned.Count} games ({added} new) — {drops.Count} with card drops", Severity.Success);
            }
            catch
            {
                Snackbar.Add($"Synced {owned.Count} games — {added} new (card drops sync failed)", Severity.Success);
            }

            await RefreshAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error); }
        finally { _syncing = false; }
    }

    Color StatusColor(GameStatus s) => s switch
    {
        GameStatus.Playing => Color.Success,
        GameStatus.Completed => Color.Info,
        _ => Color.Default
    };
}
