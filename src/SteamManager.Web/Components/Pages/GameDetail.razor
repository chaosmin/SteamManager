@page "/games/{Id:int}"
@rendermode InteractiveServer
@inject AppDbContext Db
@inject NavigationManager Nav
@inject AchievementHandler AchHandler
@inject IGameIdleService IdleService
@inject IGameRefreshService RefreshService
@inject ISnackbar Snackbar
@using SteamManager.Core.Services
@using SteamManager.Infrastructure.Persistence
@using SteamManager.Infrastructure.Steam
@using SteamManager.Core.Models
@using Microsoft.EntityFrameworkCore

@if (_game == null)
{
    <!-- Skeleton for game header -->
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="460px" Height="180px" Class="mb-6" Style="border-radius:8px;max-width:100%" />
    <MudSkeleton SkeletonType="SkeletonType.Text" Width="300px" Height="36px" Class="mb-2" />
    <MudSkeleton SkeletonType="SkeletonType.Text" Width="480px" Class="mb-4" />
    @for (int i = 0; i < 6; i++)
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="52px" Class="mb-1" Style="border-radius:4px" />
    }
}
else
{
    <MudOverlay Visible="_saving" DarkBackground="true" ZIndex="9999">
        <div class="d-flex flex-column align-center gap-3">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
            <MudText Typo="Typo.body1" Style="color:#fff">Saving &amp; scheduling achievements…</MudText>
        </div>
    </MudOverlay>

    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 px-0" />

    <!-- Game header -->
    <div style="position:relative;margin-bottom:24px">
        <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/@(_game.AppId)/header.jpg"
             style="width:100%;max-width:460px;border-radius:8px;display:block"
             onerror="this.style.display='none'" />
    </div>

    <div class="mb-1">
        <MudText Typo="Typo.h4">@(_game.NameI18n ?? _game.Name)</MudText>
    </div>
    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.6)" Class="mb-4">
        App ID: @_game.AppId &nbsp;|&nbsp;
        Idle time: @($"{_game.SteamPlaytimeAtRefresh / 60.0:F1}h") / @(_game.TargetMinutes.HasValue ? $"{_game.TargetMinutes.Value / 60.0:F2}h" : "10h")
        @if (_total > 0)
        {
            <span> &nbsp;|&nbsp; Achievements: @_unlocked / @_total unlocked</span>
        }
        @if (_game.AchievementsCachedAt.HasValue)
        {
            <span> &nbsp;|&nbsp; Last synced: @FormatTime(_game.AchievementsCachedAt.Value)</span>
        }
    </MudText>

    <!-- Reference Player Panel -->
    <MudExpansionPanel @bind-IsExpanded="_playerPanelExpanded" Dense="true" Class="mb-4">
        <TitleContent>
            <div class="d-flex align-center gap-2">
                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                <MudText Typo="Typo.body2">Reference Player</MudText>
                @if (_hasPlayer)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small"
                             Style="color:#22C55E;font-size:8px" />
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.5)">@_playerUrlShort</MudText>
                }
            </div>
        </TitleContent>
        <ChildContent>
            @if (!_hasPlayer)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    No reference player configured. Add a SteamHunters player URL to enable scheduled unlocking.
                </MudAlert>
            }
            @if (_playerError != null)
            {
                <MudAlert Severity="@(_playerError.Contains("Burst") ? Severity.Warning : Severity.Error)"
                          Dense="true" Class="mb-3">@_playerError</MudAlert>
            }
            <MudTextField @bind-Value="_playerUrl" Label="SteamHunters Player URL"
                          Variant="Variant.Outlined" FullWidth="true" Class="mb-3"
                          Placeholder="https://steamhunters.com/profiles/76561198012345678"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Link" />
            <MudCheckBox @bind-Value="_overrideBurst" Dense="true" Class="mb-3"
                         Label="Override burst detection" />
            <div class="d-flex flex-wrap gap-2 mt-3 mb-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SavePlayer">Save</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                           Disabled="@(!_hasPlayer)" OnClick="ForceRefreshGame">Force Replay</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.OpenInNew"
                           Href="@($"https://steamhunters.com/apps/{_game?.AppId}/users?sort=achievements")"
                           Target="_blank">SteamHunters</MudButton>
                @if (_hasPlayer)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="RemovePlayer">
                        Remove Player
                    </MudButton>
                }
            </div>
        </ChildContent>
    </MudExpansionPanel>

    @if (_loading)
    {
        <div class="d-flex align-center gap-3 my-4">
            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
            <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.6)">Loading achievements from Steam...</MudText>
        </div>
    }
    else if (_loadError != null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
    }
    else if (!_game.Achievements.Any())
    {
        <MudAlert Severity="Severity.Info">
            This game has no achievements, or they are not available via Steam API.
        </MudAlert>
    }
    else
    {
        <MudTable T="Achievement" Items="_game.Achievements
                      .OrderBy(a =>
                          a.IsUnlocked ? 3 :
                          a.ScheduledUnlockAt.HasValue && a.ScheduledUnlockAt.Value <= DateTime.UtcNow ? 0 :
                          a.ScheduledUnlockAt.HasValue ? 1 : 2)
                      .ThenBy(a => a.IsUnlocked
                          ? long.MaxValue - (a.UnlockedAt ?? DateTime.MinValue).Ticks
                          : (a.ScheduledUnlockAt ?? DateTime.MinValue).Ticks)"
                  Hover="true" Elevation="2" Dense="true"
                  RowClassFunc="@((ach, _) => GetAchRowClass(ach))">
            <HeaderContent>
                <MudTh Style="width:56px"></MudTh>
                <MudTh>Achievement</MudTh>
                <MudTh Style="width:120px">Global %</MudTh>
                <MudTh Style="width:165px">Scheduled At</MudTh>
                <MudTh Style="width:110px">Status</MudTh>
                <MudTh Style="width:165px">Time</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    @{
                        var icon = context.IsUnlocked ? context.IconUrl : context.IconGrayUrl;
                    }
                    @if (icon != null)
                    {
                        <img src="@icon" width="40" height="40" style="border-radius:6px;display:block" />
                    }
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Style="font-weight:500">@(context.DisplayNameI18n ?? context.DisplayName)</MudText>
                    @{
                        var desc = context.DescriptionI18n ?? context.Description;
                    }
                    @if (!string.IsNullOrWhiteSpace(desc))
                    {
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.55)">@desc</MudText>
                    }
                </MudTd>
                <MudTd>
                    <div class="d-flex align-center gap-1">
                        <MudProgressLinear Value="@((double)context.GlobalPercent)" Size="Size.Small" Style="width:60px;flex-shrink:0" Rounded="true" />
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.55)">@($"{context.GlobalPercent:F1}%")</MudText>
                    </div>
                </MudTd>

                @* Scheduled At *@
                <MudTd Style="color:rgba(255,255,255,0.55);font-size:0.8rem">
                    @(context.ScheduledUnlockAt.HasValue
                        ? context.ScheduledUnlockAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                        : "—")
                </MudTd>

                @* Status chip *@
                <MudTd>
                    @{
                        var (chipLabel, chipHex) = context.IsUnlocked ? ("Unlocked", "#22C55E")
                            : context.ScheduledUnlockAt.HasValue ? ("Scheduled", "#3B82F6")
                            : ("Locked", "#6B7280");
                    }
                    <MudChip T="string" Size="Size.Small" Style="@($"background:{chipHex};color:#fff")">@chipLabel</MudChip>
                </MudTd>

                @* Time *@
                <MudTd>
                    @if (context.IsUnlocked && context.UnlockedAt.HasValue)
                    {
                        <span style="color:#22C55E;font-size:0.8rem">
                            @context.UnlockedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                        </span>
                    }
                    else if (context.ScheduledUnlockAt.HasValue)
                    {
                        var rem = context.ScheduledUnlockAt.Value - DateTime.UtcNow;
                        @if (rem > TimeSpan.Zero)
                        {
                            <span style="color:#3B82F6;font-size:0.8rem">
                                in @((int)rem.TotalHours)h @(rem.Minutes)m
                            </span>
                        }
                        else
                        {
                            <span style="color:#F59E0B;font-size:0.8rem">
                                Pending <span class="pending-dot"
                                    style="display:inline-block;width:6px;height:6px;border-radius:50%;background:#F59E0B"></span>
                            </span>
                        }
                    }
                    else
                    {
                        <span style="color:rgba(255,255,255,0.3)">—</span>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

<style>
    .row-unlocked { opacity: 0.55; }
    .row-next { border-left: 3px solid #3B82F6; background: rgba(59,130,246,0.05); }
    .row-pending { border-left: 3px solid #F59E0B; background: rgba(245,158,11,0.04); }
    @@keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
    .pending-dot { animation: pulse-dot 1.5s ease-in-out infinite; }
</style>

@code {
    [Parameter] public int Id { get; set; }

    Game? _game;
    int _total;
    int _unlocked;
    bool _loading;
    string? _loadError;
    string _timezone = "UTC";

    // Reference player state
    private bool _hasPlayer;
    private string _playerUrl = "";
    private string _playerUrlShort = "";
    private bool _overrideBurst;
    private bool _playerPanelExpanded;
    private string? _playerError;
    private bool _saving;

    private List<BreadcrumbItem> _breadcrumbs =
    [
        new("Games", href: "/games"),
        new("Detail", href: null, disabled: true),
    ];

    protected override async Task OnInitializedAsync()
    {
        var cfg = await Db.SteamConfigs.AsNoTracking().FirstOrDefaultAsync();
        _timezone = cfg?.DisplayTimezone ?? "UTC";

        _game = await Db.Games.AsNoTracking()
            .Include(g => g.Achievements)
            .Include(g => g.ReferencePlayer)
            .FirstOrDefaultAsync(g => g.Id == Id);

        if (_game == null) return;
        _breadcrumbs[1] = new(_game.NameI18n ?? _game.Name, href: null, disabled: true);

        await LoadReferencePlayerAsync();

        if (_game.Achievements.Count == 0)
            await RefreshAchievementsAsync();
        else
            UpdateCounts();
    }

    private async Task LoadReferencePlayerAsync()
    {
        var refPlayer = await Db.GameReferencePlayers
            .FirstOrDefaultAsync(r => r.GameId == _game!.Id);
        _hasPlayer = refPlayer != null;
        if (refPlayer != null)
        {
            _playerUrl = refPlayer.PlayerUrl;
            _playerUrlShort = _playerUrl.Length > 50 ? _playerUrl[..50] + "…" : _playerUrl;
            _overrideBurst = refPlayer.OverrideBurstCheck;
        }
    }

    private async Task SavePlayer()
    {
        _playerError = null;
        if (string.IsNullOrWhiteSpace(_playerUrl))
        {
            _playerError = "Player URL is required.";
            return;
        }
        _saving = true;
        StateHasChanged();
        try
        {
            var refPlayer = await Db.GameReferencePlayers.FirstOrDefaultAsync(r => r.GameId == _game!.Id);
            if (refPlayer == null)
                Db.GameReferencePlayers.Add(new GameReferencePlayer
                    { GameId = _game!.Id, PlayerUrl = _playerUrl.Trim(), OverrideBurstCheck = _overrideBurst });
            else
                { refPlayer.PlayerUrl = _playerUrl.Trim(); refPlayer.OverrideBurstCheck = _overrideBurst; }
            await Db.SaveChangesAsync();
            await LoadReferencePlayerAsync();
            await RefreshService.RefreshAsync(_game!.Id, _game.AppId);
            await RefreshAchievementsAsync();
            Snackbar.Add("Reference player saved and achievements scheduled.", Severity.Success);
        }
        catch (Exception ex) { _playerError = ex.Message; }
        finally { _saving = false; StateHasChanged(); }
    }

    private async Task RemovePlayer()
    {
        var refPlayer = await Db.GameReferencePlayers.FirstOrDefaultAsync(r => r.GameId == _game!.Id);
        if (refPlayer != null) { Db.GameReferencePlayers.Remove(refPlayer); await Db.SaveChangesAsync(); }
        _hasPlayer = false; _playerUrl = ""; _playerUrlShort = "";
    }

    private async Task ForceRefreshGame()
    {
        _playerError = null;
        try
        {
            await RefreshService.ForceRefreshAsync(_game!.Id, _game.AppId);
            await RefreshAchievementsAsync();
            Snackbar.Add("Force refresh complete — all achievements rescheduled.", Severity.Success);
        }
        catch (Exception ex) { _playerError = ex.Message; StateHasChanged(); }
    }

    private static string GetAchRowClass(Achievement ach)
    {
        if (ach.IsUnlocked) return "row-unlocked";
        if (ach.ScheduledUnlockAt.HasValue && ach.ScheduledUnlockAt.Value > DateTime.UtcNow) return "row-next";
        if (ach.ScheduledUnlockAt.HasValue) return "row-pending";
        return "";
    }

    async Task RefreshAchievementsAsync()
    {
        if (_game == null) return;
        _loading = true;
        _loadError = null;
        StateHasChanged();
        try
        {
            _game = await Db.Games
                .Include(g => g.Achievements)
                .Include(g => g.ReferencePlayer)
                .FirstOrDefaultAsync(g => g.Id == Id);
            UpdateCounts();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load achievements: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    void UpdateCounts()
    {
        if (_game == null) return;
        _total = _game.Achievements.Count;
        _unlocked = _game.Achievements.Count(a => a.IsUnlocked);
    }

    string FormatTime(DateTime utc, string format = "yyyy-yyyy-MM-dd HH:mm")
    {
        try
        {
            var tz = TimeZoneInfo.FindSystemTimeZoneById(_timezone);
            return TimeZoneInfo.ConvertTimeFromUtc(utc, tz).ToString(format);
        }
        catch
        {
            return utc.ToString(format);
        }
    }
}
