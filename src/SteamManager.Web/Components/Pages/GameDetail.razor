@page "/games/{Id:int}"
@rendermode InteractiveServer
@inject AppDbContext Db
@inject NavigationManager Nav
@inject AchievementHandler AchHandler
@inject IGameIdleService IdleService
@inject ISnackbar Snackbar
@using SteamManager.Core.Services
@using SteamManager.Infrastructure.Persistence
@using SteamManager.Infrastructure.Steam
@using SteamManager.Core.Models
@using Microsoft.EntityFrameworkCore

@if (_game == null)
{
    <!-- Skeleton for game header -->
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="460px" Height="180px" Class="mb-6" Style="border-radius:8px;max-width:100%" />
    <MudSkeleton SkeletonType="SkeletonType.Text" Width="300px" Height="36px" Class="mb-2" />
    <MudSkeleton SkeletonType="SkeletonType.Text" Width="480px" Class="mb-4" />
    @for (int i = 0; i < 6; i++)
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="52px" Class="mb-1" Style="border-radius:4px" />
    }
}
else
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 px-0" />

    <!-- Game header -->
    <div style="position:relative;margin-bottom:24px">
        <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/@(_game.AppId)/header.jpg"
             style="width:100%;max-width:460px;border-radius:8px;display:block"
             onerror="this.style.display='none'" />
    </div>

    <div class="d-flex align-center justify-space-between mb-1">
        <MudText Typo="Typo.h4">@(_game.NameI18n ?? _game.Name)</MudText>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Replay"
                       OnClick="ForceReplayAsync"
                       Disabled="_forceReplaying || _loading">
                @(_forceReplaying ? "Resetting..." : "Force Replay")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="RefreshAchievementsAsync"
                       Disabled="_loading || _forceReplaying">
                @(_loading ? "Refreshing..." : "Refresh")
            </MudButton>
        </div>
    </div>
    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.6)" Class="mb-2">
        App ID: @_game.AppId &nbsp;|&nbsp;
        Idle time: @($"{_game.SteamPlaytimeAtRefresh / 60.0:F1}h") / @(_game.TargetMinutes.HasValue ? $"{_game.TargetMinutes.Value / 60.0:F2}h" : "10h")
        @if (_total > 0)
        {
            <span> &nbsp;|&nbsp; Achievements: @_unlocked / @_total unlocked</span>
        }
        @if (_game.AchievementsCachedAt.HasValue)
        {
            <span> &nbsp;|&nbsp; Last synced: @FormatTime(_game.AchievementsCachedAt.Value)</span>
        }
    </MudText>

    <div class="d-flex align-center gap-2 mb-4" style="flex-wrap:wrap">
        @if (_editingUrl)
        {
            <MudTextField @bind-Value="_referenceUrl" Placeholder="https://steamhunter.com/app/..."
                          Style="min-width:320px" Margin="Margin.Dense" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Link" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       OnClick="SaveReferenceUrlAsync">Save</MudButton>
            <MudButton Variant="Variant.Text" Size="Size.Small"
                       OnClick="@(() => { _editingUrl = false; _referenceUrl = _game.ReferencePlayer?.PlayerUrl; })">Cancel</MudButton>
        }
        else if (!string.IsNullOrWhiteSpace(_game.ReferencePlayer?.PlayerUrl))
        {
            <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" Style="color:rgba(255,255,255,0.45)" />
            <MudLink Href="@_game.ReferencePlayer!.PlayerUrl" Target="_blank" Typo="Typo.body2"
                     Style="color:#66c0f4;max-width:480px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                @_game.ReferencePlayer!.PlayerUrl
            </MudLink>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                           OnClick="@(() => _editingUrl = true)" Title="Edit reference URL" />
        }
        else
        {
            <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.AddLink"
                       Style="color:rgba(255,255,255,0.4)"
                       OnClick="@(() => _editingUrl = true)">Set reference URL</MudButton>
        }
    </div>

    @if (_loading)
    {
        <div class="d-flex align-center gap-3 my-4">
            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
            <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.6)">Loading achievements from Steam...</MudText>
        </div>
    }
    else if (_loadError != null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
    }
    else if (!_game.Achievements.Any())
    {
        <MudAlert Severity="Severity.Info">
            This game has no achievements, or they are not available via Steam API.
        </MudAlert>
    }
    else
    {
        <MudTable Items="_game.Achievements.OrderBy(a => a.ScheduledUnlockAt ?? DateTime.MaxValue)"
                  Hover="true" Elevation="2" Dense="true">
            <HeaderContent>
                <MudTh Style="width:56px"></MudTh>
                <MudTh>Achievement</MudTh>
                <MudTh Style="width:120px">Global %</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Scheduled At</MudTh>
                <MudTh>Unlocked At</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    @{
                        var icon = context.IsUnlocked ? context.IconUrl : context.IconGrayUrl;
                    }
                    @if (icon != null)
                    {
                        <img src="@icon" width="40" height="40" style="border-radius:6px;display:block" />
                    }
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Style="font-weight:500">@(context.DisplayNameI18n ?? context.DisplayName)</MudText>
                    @{
                        var desc = context.DescriptionI18n ?? context.Description;
                    }
                    @if (!string.IsNullOrWhiteSpace(desc))
                    {
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.55)">@desc</MudText>
                    }
                </MudTd>
                <MudTd>
                    <div class="d-flex align-center gap-1">
                        <MudProgressLinear Value="@((double)context.GlobalPercent)" Size="Size.Small" Style="width:60px;flex-shrink:0" Rounded="true" />
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.55)">@($"{context.GlobalPercent:F1}%")</MudText>
                    </div>
                </MudTd>
                <MudTd>
                    @if (context.IsUnlocked)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Unlocked</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">Locked</MudChip>
                    }
                </MudTd>
                <MudTd>
                    @if (context.ScheduledUnlockAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.6)">
                            @FormatTime(context.ScheduledUnlockAt.Value)
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.3)">—</MudText>
                    }
                </MudTd>
                <MudTd>
                    @if (context.IsUnlocked && context.UnlockedAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Success">
                            @FormatTime(context.UnlockedAt.Value)
                        </MudText>
                    }
                    else if (!context.IsUnlocked && context.ScheduledUnlockAt.HasValue)
                    {
                        @if (context.ScheduledUnlockAt.Value <= DateTime.UtcNow)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning">Pending unlock</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.6)">
                                in @($"{(context.ScheduledUnlockAt.Value - DateTime.UtcNow).TotalHours:F1}h")
                            </MudText>
                        }
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    [Parameter] public int Id { get; set; }

    Game? _game;
    int _total;
    int _unlocked;
    bool _loading;
    bool _forceReplaying;
    string? _loadError;
    string _timezone = "UTC";
    string? _referenceUrl;
    bool _editingUrl;

    private List<BreadcrumbItem> _breadcrumbs =
    [
        new("Games", href: "/games"),
        new("Detail", href: null, disabled: true),
    ];

    protected override async Task OnInitializedAsync()
    {
        var cfg = await Db.SteamConfigs.AsNoTracking().FirstOrDefaultAsync();
        _timezone = cfg?.DisplayTimezone ?? "UTC";

        _game = await Db.Games.AsNoTracking()
            .Include(g => g.Achievements)
            .Include(g => g.ReferencePlayer)
            .FirstOrDefaultAsync(g => g.Id == Id);

        if (_game == null) return;
        _breadcrumbs[1] = new(_game.NameI18n ?? _game.Name, href: null, disabled: true);
        _referenceUrl = _game.ReferencePlayer?.PlayerUrl;

        if (_game.Achievements.Count == 0)
            await RefreshAchievementsAsync();
        else
            UpdateCounts();
    }

    async Task RefreshAchievementsAsync()
    {
        if (_game == null) return;
        _loading = true;
        _loadError = null;
        StateHasChanged();
        try
        {
            _game = await Db.Games
                .Include(g => g.Achievements)
                .Include(g => g.ReferencePlayer)
                .FirstOrDefaultAsync(g => g.Id == Id);
            UpdateCounts();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load achievements: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    async Task ForceReplayAsync()
    {
        if (_game == null) return;
        _forceReplaying = true;
        StateHasChanged();
        try
        {
            // 1. Stop current idle session
            await IdleService.StopAsync(_game.AppId);

            // 2. Lock all unlocked achievements on Steam
            var toLock = _game.Achievements.Where(a => a.IsUnlocked).Select(a => a.ApiName).ToList();
            foreach (var apiName in toLock)
                await AchHandler.LockAchievementAsync(_game.AppId, apiName);

            // 3. Reset DB — achievements only (playtime preserved; scheduler uses session timer)
            var game = await Db.Games.Include(g => g.Achievements).FirstAsync(g => g.Id == _game.Id);
            game.Status = GameStatus.Idle;
            foreach (var ach in game.Achievements)
            {
                ach.IsUnlocked = false;
                ach.UnlockedAt = null;
            }
            await Db.SaveChangesAsync();

            // 4. Start fresh idle
            await IdleService.StartAsync(_game.AppId);

            // 5. Reload page data
            _game = await Db.Games.AsNoTracking().Include(g => g.Achievements).Include(g => g.ReferencePlayer).FirstOrDefaultAsync(g => g.Id == Id);
            UpdateCounts();
            Snackbar.Add("Force replay started — all achievements reset and idling restarted", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Force replay failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _forceReplaying = false;
            StateHasChanged();
        }
    }

    async Task SaveReferenceUrlAsync()
    {
        // TODO Task 12: persist to GameReferencePlayer table
        _editingUrl = false;
        await Task.CompletedTask;
        Snackbar.Add("Reference player URL (save not yet implemented — coming in Task 12)", Severity.Info);
    }

    void UpdateCounts()
    {
        if (_game == null) return;
        _total = _game.Achievements.Count;
        _unlocked = _game.Achievements.Count(a => a.IsUnlocked);
    }

    string FormatTime(DateTime utc, string format = "yyyy-MM-dd HH:mm")
    {
        try
        {
            var tz = TimeZoneInfo.FindSystemTimeZoneById(_timezone);
            return TimeZoneInfo.ConvertTimeFromUtc(utc, tz).ToString(format);
        }
        catch
        {
            return utc.ToString(format);
        }
    }
}
