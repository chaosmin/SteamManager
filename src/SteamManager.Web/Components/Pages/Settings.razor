@page "/settings"
@rendermode InteractiveServer
@inject ISteamSessionService Session
@inject ISyncService SyncService
@inject IConfiguration Config
@inject AppDbContext Db
@inject ISnackbar Snackbar
@implements IDisposable
@using SteamManager.Core.Services
@using SteamManager.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore

<MudText Typo="Typo.h4" Class="mb-4">Settings</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudCard Elevation="2" Class="mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Custom.Brands.Steam" Class="mr-2" />
                        Steam Account
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (Session.State == LoginState.LoggedIn)
                {
                    <MudAlert Severity="Severity.Success" Class="mb-3">
                        Logged in as <strong>@Session.DisplayName</strong>
                    </MudAlert>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="Logout">Logout</MudButton>
                }
                else if (Session.State == LoginState.AwaitingTwoFactor)
                {
                    <MudAlert Severity="Severity.Info" Class="mb-3">Enter the code from your Steam Authenticator app</MudAlert>
                    <MudTextField @bind-Value="_twoFaCode" Label="2FA Code" Variant="Variant.Outlined"
                                  MaxLength="5" FullWidth="true" Class="mb-3" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit2Fa"
                               Disabled="_busy" FullWidth="true">
                        @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Submit Code
                    </MudButton>
                }
                else
                {
                    <MudTextField @bind-Value="_username" Label="Steam Username" Variant="Variant.Outlined"
                                  FullWidth="true" Class="mb-3" />
                    <MudTextField @bind-Value="_password" Label="Steam Password" InputType="InputType.Password"
                                  Variant="Variant.Outlined" FullWidth="true" Class="mb-3" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Login"
                               Disabled="_busy" FullWidth="true">
                        @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Login
                    </MudButton>
                }
            </MudCardContent>
        </MudCard>

        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent><MudText Typo="Typo.h6">Steam Web API Key</MudText></CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField @bind-Value="_apiKey" Label="API Key" Variant="Variant.Outlined"
                              FullWidth="true" Class="mb-3"
                              HelperText="Get yours at steamcommunity.com/dev/apikey" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveApiKey">Save</MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent><MudText Typo="Typo.h6">Background Sync</MudText></CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField @bind-Value="_syncCron" Label="Schedule (cron expression)"
                              Variant="Variant.Outlined" FullWidth="true" Class="mb-1"
                              HelperText="5-field: min hour day month weekday  e.g. 0 0 * * * = daily midnight"
                              Error="@(_cronError != null)" ErrorText="@_cronError" />
                @if (SyncService.NextRunUtc.HasValue && !SyncService.IsSyncing)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                        Next run: @SyncService.NextRunUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </MudText>
                }

                <div class="d-flex gap-3 mt-2 mb-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSyncCron"
                               Disabled="SyncService.IsSyncing">Save</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Sync"
                               OnClick="SyncNow" Disabled="SyncService.IsSyncing">
                        @(SyncService.IsSyncing ? "Syncing..." : "Sync Now")
                    </MudButton>
                </div>

                @if (SyncService.IsSyncing || SyncService.SyncStatusMessage != null)
                {
                    <MudProgressLinear Value="@SyncService.SyncProgress"
                                       Color="@(SyncService.IsSyncing ? Color.Primary : Color.Success)"
                                       Rounded="true" Size="Size.Medium" Class="mb-2" />
                    <MudText Typo="Typo.body2">
                        @SyncService.SyncStatusMessage
                    </MudText>
                }
            </MudCardContent>
        </MudCard>
        <MudCard Elevation="2" Class="mt-4">
            <MudCardHeader>
                <CardHeaderContent><MudText Typo="Typo.h6">Queue Settings</MudText></CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudNumericField @bind-Value="_maxConcurrentGames" Label="Max Concurrent Games"
                                 Variant="Variant.Outlined" FullWidth="true" Class="mb-3"
                                 Min="1" Max="32"
                                 HelperText="How many games can idle simultaneously" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveQueueSettings">Save</MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    string _username = "", _password = "", _twoFaCode = "", _apiKey = "";
    string _syncCron = "0 0 * * *";
    string? _cronError;
    int _maxConcurrentGames = 1;
    bool _busy;

    protected override async Task OnInitializedAsync()
    {
        Session.StateChanged += OnSessionChanged;
        SyncService.SyncStateChanged += OnSyncChanged;

        var cfg = await Db.SteamConfigs.FirstOrDefaultAsync();
        if (cfg != null)
        {
            _apiKey = cfg.WebApiKey ?? "";
            _syncCron = cfg.SyncCron;
            _maxConcurrentGames = cfg.MaxConcurrentGames;
        }
    }

    void OnSessionChanged() => InvokeAsync(StateHasChanged);
    void OnSyncChanged() => InvokeAsync(StateHasChanged);

    async Task Login()
    {
        _busy = true;
        var state = await Session.BeginLoginAsync(_username, _password);
        _busy = false;
        switch (state)
        {
            case LoginState.AwaitingTwoFactor: Snackbar.Add("Enter your 2FA code", Severity.Info); break;
            case LoginState.LoggedIn: Snackbar.Add("Logged in!", Severity.Success); break;
            default: Snackbar.Add("Login failed — check username and password", Severity.Error); break;
        }
    }

    async Task Submit2Fa()
    {
        _busy = true;
        var ok = await Session.SubmitTwoFactorCodeAsync(_twoFaCode);
        _busy = false;
        if (ok) Snackbar.Add("Steam session established!", Severity.Success);
        else Snackbar.Add("Invalid 2FA code — try again", Severity.Error);
    }

    async Task Logout()
    {
        await Session.LogoutAsync();
        Snackbar.Add("Logged out", Severity.Info);
    }

    async Task SaveApiKey()
    {
        var cfg = await Db.SteamConfigs.FirstOrDefaultAsync() ?? new SteamManager.Core.Models.SteamConfig();
        cfg.WebApiKey = _apiKey;
        if (cfg.Id == 0) Db.SteamConfigs.Add(cfg);
        await Db.SaveChangesAsync();
        Snackbar.Add("API key saved", Severity.Success);
    }

    async Task SaveSyncCron()
    {
        _cronError = ValidateCron(_syncCron);
        if (_cronError != null) return;
        var cfg = await Db.SteamConfigs.FirstOrDefaultAsync() ?? new SteamManager.Core.Models.SteamConfig();
        cfg.SyncCron = _syncCron;
        if (cfg.Id == 0) Db.SteamConfigs.Add(cfg);
        await Db.SaveChangesAsync();
        Snackbar.Add("Sync schedule saved", Severity.Success);
    }

    async Task SaveQueueSettings()
    {
        var cfg = await Db.SteamConfigs.FirstOrDefaultAsync() ?? new SteamManager.Core.Models.SteamConfig();
        cfg.MaxConcurrentGames = Math.Max(1, _maxConcurrentGames);
        if (cfg.Id == 0) Db.SteamConfigs.Add(cfg);
        await Db.SaveChangesAsync();
        Snackbar.Add("Queue settings saved", Severity.Success);
    }

    async Task SyncNow()
    {
        await SyncService.TriggerAsync();
        Snackbar.Add("Sync started", Severity.Info);
    }

    static string? ValidateCron(string expr)
    {
        try { Cronos.CronExpression.Parse(expr, Cronos.CronFormat.Standard); return null; }
        catch (Exception ex) { return ex.Message; }
    }

    public void Dispose()
    {
        Session.StateChanged -= OnSessionChanged;
        SyncService.SyncStateChanged -= OnSyncChanged;
    }
}
