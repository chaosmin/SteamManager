@page "/login"

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="d-flex align-center justify-center" Style="min-height:100vh">
    <MudCard Elevation="8" Style="width:100%">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Align="Align.Center">
                    <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Class="mr-2" />
                    SteamManager
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <form method="post" action="/api/login" data-enhance="false">
                @if (ShowError)
                {
                    <MudAlert Severity="Severity.Error" Class="mb-3">Incorrect password</MudAlert>
                }
                <div class="mb-4">
                    <input type="password" name="password" placeholder="Access Password"
                           style="width:100%;padding:16px;background:#2a475e;color:rgba(255,255,255,0.87);border:1px solid rgba(255,255,255,0.23);border-radius:4px;font-size:1rem;outline:none;box-sizing:border-box;" />
                </div>
                <button type="submit"
                        style="width:100%;padding:12px;background:#66c0f4;color:#1b2838;border:none;border-radius:4px;font-size:1rem;font-weight:600;cursor:pointer;letter-spacing:0.05em;">
                    ENTER
                </button>
            </form>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    bool ShowError => !string.IsNullOrEmpty(Error);
}
