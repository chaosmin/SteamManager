@page "/login"
@inject IConfiguration Config
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpCtx

<h3>Login</h3>
<input type="password" @bind="_password" placeholder="Access password" />
<button @onclick="Submit">Enter</button>
@if (_error != null) { <p style="color:red">@_error</p> }

@code {
    string _password = "";
    string? _error;

    void Submit()
    {
        var stored = Config["UI_ACCESS_PASSWORD"]
            ?? Environment.GetEnvironmentVariable("UI_ACCESS_PASSWORD");
        if (string.IsNullOrWhiteSpace(stored)) { Nav.NavigateTo("/"); return; }

        var hash = SteamManager.Web.Middleware.UiAuthMiddleware.Hash(stored);
        var input = SteamManager.Web.Middleware.UiAuthMiddleware.Hash(_password);
        if (input == hash)
        {
            HttpCtx.HttpContext!.Response.Cookies.Append("ui_auth", hash,
                new CookieOptions { Expires = DateTimeOffset.UtcNow.AddDays(30), HttpOnly = true });
            Nav.NavigateTo("/");
        }
        else
        {
            _error = "Incorrect password";
        }
    }
}
